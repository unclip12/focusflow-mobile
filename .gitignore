# Dart/Flutter
.dart_tool/
build/
*.iml
.idea/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
**/doc/api/

# Android build outputs only (keep android/ tracked)
android/.gradle/
android/local.properties
android/captures/
/android/app/debug
/android/app/profile
/android/app/release

# iOS build outputs only (keep ios/ tracked)
ios/Pods/
ios/.symlinks/
ios/Flutter/.last_build_id

# 🔒 SECURITY: Firebase configuration files — NEVER commit these
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
lib/firebase_options.dart

# 🔑 SECURITY: Android release signing keystore — NEVER commit
*.jks
*.keystore
key.properties
keystore-base64.txt
android/app/release-keystore.jks
android/key.properties

# 🌍 Environment variables — NEVER commit
.env
.env.local
.env.*.local

# 🤖 AI agent workspace data — NEVER commit
# Codex environment config (auto-generated, not a secret but noisy)
# NOTE: .codex/environments/environment.toml is safe but unnecessary to track
# Keep .codex/ committed if you want Codex environment setup shared with team
# Remove the # below to block it:
# .codex/
.cognetivy/
.cursor/mcp.json
.claude/
.antigravity/

# API keys in Dart files
**/*secret*.dart
**/*apikey*.dart
**/*_keys.dart

# macOS
.DS_Store

# VSCode
.vscode/launch.json

# Generated/noisy files that don't need tracking
git_log.txt

node_modules/
scripts/

# Figma design reference — local only, not part of Flutter app
Ultra-Premium iOS App Redesign/
